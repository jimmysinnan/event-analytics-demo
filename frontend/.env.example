# ── Mode développement local ──────────────────────────────────────────────────
# Copier en .env.local pour le dev ou le package local

VITE_API_URL=http://localhost:8001
VITE_API_TOKEN=
VITE_APP_MODE=demo


# ── Mode hébergement dédié ────────────────────────────────────────────────────
# Pour builder le frontend à déployer sur le serveur (build partagé entre clients)
# Utiliser .env.production (déjà configuré) ou exporter ces vars avant npm run build :
#
#   VITE_API_URL=          ← vide = appels /api/... relatifs, Nginx fait le routage
#   VITE_API_TOKEN=        ← vide = auth gérée par Nginx Basic Auth (recommandé V1)
#   VITE_APP_MODE=production
#
# IMPORTANT : Ne jamais mettre ANTHROPIC_API_KEY dans une variable VITE_*
# La clé Anthropic reste exclusivement dans le backend (.env serveur)
