# URL du backend Event Analytics
VITE_API_URL=http://localhost:8001

# Token d'authentification API (laisser vide en local sans auth)
VITE_API_TOKEN=

# Mode application : demo | production
# demo       = données de démonstration affichées dans les modules métier
# production = seules les données importées par le client sont affichées
VITE_APP_MODE=demo
