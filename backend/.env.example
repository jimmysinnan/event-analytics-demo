# ── Event Analytics — Backend configuration ──────────────────────────────────
# Copier ce fichier en .env et remplir les valeurs

# Clé API Anthropic — requise pour la génération de rapports IA
# Obtenir sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Nom de l'application (affiché dans les PDF et les réponses API)
APP_NAME=Event Analytics

# Token d'authentification API (laisser vide pour désactiver en local)
# Si défini, toutes les requêtes doivent inclure : X-API-Token: <valeur>
API_SECRET_TOKEN=

# Dossier contenant les PDF de référence (optionnel)
# Si absent, le bouton "Consulter PDF" retourne une erreur 503 propre
PDF_SOURCE_DIR=

# Origines CORS supplémentaires (séparées par des virgules)
# Ex: https://mondomaine.com,https://demo.mondomaine.com
CORS_ORIGINS=
