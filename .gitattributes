# Forcer LF pour tous les scripts shell (évite CRLF sur Windows qui cassent bash)
*.sh    text eol=lf
*.bash  text eol=lf

# Texte standard
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.env   text eol=lf
*.conf  text eol=lf
*.service text eol=lf

# Binaires — ne pas toucher
*.db    binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.ico   binary
*.woff  binary
*.woff2 binary
